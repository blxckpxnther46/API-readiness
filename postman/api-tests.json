{
  "info": {
    "name": "API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Users",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/users"
      }
    },
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "body": {
          "mode": "raw",
          "raw": "{\"name\":\"test\",\"email\":\"test@mail.com\"}"
        },
        "url": "{{baseUrl}}/api/users"
      }
    },
    {
      "name": "Update User",
      "request": {
        "method": "PUT",
        "url": "{{baseUrl}}/api/users/{{id}}"
      }
    },
    {
      "name": "Delete User",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/users/{{id}}"
      }
    }
  ]
}